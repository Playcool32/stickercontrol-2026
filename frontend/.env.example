# Fase 0: el frontend usa /api (proxy de Vite hacia el backend en localhost:8000).

# Fase 2A: login con Google. Copiar este archivo a .env y completar.
# Client ID de OAuth de Google Cloud Console (mismo valor que
# GOOGLE_CLIENT_ID en backend/.env). Es publico, se incluye en el build.
VITE_GOOGLE_CLIENT_ID=
