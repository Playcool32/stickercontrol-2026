# Fase 2A: login con Google. Copiar este archivo a .env y ajustar.

# URL de la base de datos SQLite (ruta relativa a backend/)
DATABASE_URL=sqlite:///./stickercontrol.db

# Origenes permitidos para CORS (separados por coma). Debe incluir el
# origen exacto del frontend (en produccion, https://skillgames.com.ar).
CORS_ORIGINS=http://localhost:5173

# Client ID de OAuth de Google Cloud Console (mismo valor que
# VITE_GOOGLE_CLIENT_ID en frontend/.env). El backend lo usa como
# "audience" al validar el credential (ID token) recibido del frontend.
GOOGLE_CLIENT_ID=

# Secreto para firmar la cookie de sesion (SessionMiddleware). Generar uno
# por entorno con: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Cookie de sesion con flag Secure (requiere HTTPS). true en produccion,
# false en desarrollo local (http://localhost).
SESSION_COOKIE_SECURE=false
